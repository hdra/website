---
import Baselayout from '../../layouts/Baselayout.astro';
import { getCollection } from "astro:content";
import { getImage } from 'astro:assets';
import type { ImageMetadata } from 'astro';

const allPhotos = await getCollection("photography");
const sortedPhotos = allPhotos.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const formatDate = (date: Date) => {
  return date.toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'long',
    day: 'numeric'
  });
};

const allImages = import.meta.glob<{ default: ImageMetadata }>(
  '/src/content/photography/**/*.{jpg,jpeg,png,webp,gif,JPG,JPEG,PNG,WEBP}',
  { eager: true }
);

const photosWithPreviews = await Promise.all(
  sortedPhotos.map(async (photo) => {
    const entryImgs = Object.entries(allImages)
      .filter(([path]) => path.startsWith(`/src/content/photography/${photo.id}/`))
      .sort(([a], [b]) => a.localeCompare(b));

    const match = photo.data.cover
      ? entryImgs.find(([path]) => path.endsWith(`/${photo.data.cover}`)) ?? entryImgs[0]
      : entryImgs[0];

    if (!match) return { photo, previewSrc: null };

    const processed = await getImage({ src: match[1].default, width: 900, format: 'webp' });
    return { photo, previewSrc: processed.src };
  })
);
---

<Baselayout pageTitle="Photo Journal">
    <div class="section-header">
        <h2>Photo Journal</h2>
    </div>
    <p style="color: var(--secondary-color); font-size: 1rem; margin-bottom: 2.5rem; font-family: var(--font-sans);">Notes and photographs from the road.</p>

    <div class="journal-list">
        {photosWithPreviews.map(({ photo, previewSrc }) => (
            <article class="journal-entry">
                {previewSrc && (
                    <a href={`/photography/${photo.id}`} tabindex="-1" aria-hidden="true">
                        <img src={previewSrc} alt="" class="journal-preview" />
                    </a>
                )}
                <div class="journal-entry-meta">
                    <span class="date">{formatDate(photo.data.date)}</span>
                    {photo.data.location && <span class="journal-location"> · {photo.data.location}</span>}
                </div>
                <h3><a href={`/photography/${photo.id}`}>{photo.data.title}</a></h3>
                {photo.data.description && <p>{photo.data.description}</p>}
            </article>
        ))}
    </div>
</Baselayout>
